# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Xero OAuth
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback
XERO_ENCRYPTION_KEY=your-32-byte-hex-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — Monthly
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_FIRM_PRICE_ID=price_...

# Stripe Price IDs — Annual (run scripts/setup-stripe-annual-prices.ts to generate)
STRIPE_STARTER_PRICE_ID_ANNUAL=price_...
STRIPE_PROFESSIONAL_PRICE_ID_ANNUAL=price_...
STRIPE_FIRM_PRICE_ID_ANNUAL=price_...

# Postmark (email)
POSTMARK_API_KEY=your-postmark-api-key
POSTMARK_FROM_EMAIL=noreply@yourdomain.com
POSTMARK_WEBHOOK_TOKEN=your-webhook-token

# Admin backend (/filio-control)
# Set to the email address of the super-admin account
ADMIN_EMAIL=admin@yourdomain.com

# E2E Test Configuration
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_PASSWORD=your-test-password
E2E_CAN_REGISTER=false
BASE_URL=http://localhost:3000

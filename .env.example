# E2E Test Configuration
# Copy to .env.local and fill in test credentials

# Test user credentials for E2E tests
E2E_TEST_EMAIL=your-test-email@example.com
E2E_TEST_PASSWORD=your-test-password

# Set to true to enable registration tests (requires valid email for test)
E2E_CAN_REGISTER=false

# Base URL for tests (default: http://localhost:3000)
BASE_URL=http://localhost:3000
